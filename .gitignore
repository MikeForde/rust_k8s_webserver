# Ignore build output under target
target/*

# Re-include the release directory itself
!target/release/

# Ignore everything inside release
target/release/*

# Re-include the one binary we want
!target/release/hello_cargo

# Other ignores
vendor/
.vscode/
.DS_Store
**/.DS_Store

# Vendor (if still present)
vendor/

